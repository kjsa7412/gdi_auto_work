# =============================================================================
# 런타임 생성 파일/폴더 제외
# =============================================================================

# --- work 영역 (analyze/build/fix 실행 시 생성) ---
work/task/1.Prep/*
work/task/2.Working/*
work/task/3.Result/*
work/fix/1.Prep/*
work/fix/2.Working/*
work/fix/3.Result/*

# work 메타파일 (런타임에 갱신)
work/.active_context.yml
work/.lock

# --- archive (clean 시 생성) ---
archive/

# --- convention cache (cache-refresh / analyze 시 DB에서 갱신) ---
system/cache/convention/*.txt

# --- runtime (로그, 실행 스크립트 등) ---
system/runtime/

# --- 기타 ---
%programdata%/
*.pyc
__pycache__/
