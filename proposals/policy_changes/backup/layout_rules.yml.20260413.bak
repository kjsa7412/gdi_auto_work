# =============================================================================
# layout_rules.yml
# 레이아웃 규칙 정의
# 근거: GDI 프레임워크 templates/frame/ + FERP dt 모듈 레퍼런스
# =============================================================================

# -----------------------------------------------------------------------------
# 프레임 레이아웃 구조
# -----------------------------------------------------------------------------
frame_layout:
  description: "모든 화면은 프레임 레이아웃 내에서 렌더링됨"
  components:
    top: "templates/frame/top.html - 상단 네비게이션"
    left: "templates/frame/left.html - 좌측 사이드바 메뉴"
    content: "templates/frame/content.html - 메인 콘텐츠 영역"
    popup: "templates/frame/popup.html - 팝업/모달 컨테이너"
  rendering:
    description: "UiController가 pgm_path로 templates/project/{path}.html을 content 영역에 로드"
  근거: "C:/gdi/src/main/resources/templates/frame/"

# -----------------------------------------------------------------------------
# 필수 Fragment 포함 규칙
# -----------------------------------------------------------------------------
mandatory_fragments:
  - name: "top_title_button"
    tag: "<th:block th:replace=\"~{frame/top_title_button :: topTitleButtonFragment}\"></th:block>"
    position: "HTML 최상단 (html 태그 바로 다음)"
    purpose: "제목 바 + 상단 툴바 버튼 영역"
    mandatory: true

  # header와 script는 프레임 레이아웃이 전역으로 로드하므로 개별 화면에서 포함하지 않음
  # 근거: 레퍼런스 HTML에서 header/script fragment 직접 포함 안 함

# -----------------------------------------------------------------------------
# 화면 유형별 레이아웃 규칙
# -----------------------------------------------------------------------------
screen_layouts:

  list:
    description: "조회 + 목록 중심"
    structure:
      - area: "data-page"
        children:
          - area: "searchForm"
            id_pattern: "${PGM}searchForm"
            component: "webix.ui dataForm"
          - area: "data-content-wrapper"
            children:
              - area: "data-content-fill"
                children:
                  - area: "toolbar"
                    id_pattern: "${PGM}btnToolbar"
                    component: "webix.ui dataToolbar"
                    optional: true
                  - area: "mainGrid"
                    id_pattern: "${PGM}mainGrid"
                    component: "webix.ui datagrid"
    근거: "DTA010.html"

  list_detail:
    description: "좌측 목록 + 우측 상세/편집"
    variants:
      left_grid_right_form:
        description: "좌측 그리드 + 우측 폼 (SYB010, SYB020 패턴)"
        structure:
          - area: "data-content-wrapper"
            children:
              - area: "data-content-fill"
                note: "좌측 메인 그리드 (넓은 영역)"
              - area: "data-content-4-right"
                note: "우측 상세 폼 (좁은 영역, 약 20%)"
      left_grid_right_grid:
        description: "좌측 그리드 + 우측 그리드 (SYD020 패턴)"
        structure:
          - area: "data-content-wrapper"
            children:
              - area: "data-content-2-left"
                note: "좌측 마스터 그리드 (좁은 영역, 약 20%)"
              - area: "data-content-fill"
                note: "우측 상세 그리드 (넓은 영역)"
      three_split:
        description: "좌측 고정 + 우측 채움 (SYB030 패턴)"
        structure:
          - area: "data-content-wrapper"
            children:
              - area: "data-content-3-left"
                note: "좌측 그리드 (약 30%)"
              - area: "data-content-fill"
                note: "우측 그리드 (약 70%)"
    available_classes:
      - "data-content-fill: 나머지 공간 채움 (flex-grow)"
      - "data-content-2-left: 좌측 약 20%"
      - "data-content-3-left: 좌측 약 30%"
      - "data-content-4-right: 우측 약 20%"
    rule: "반드시 1개는 data-content-fill로 구성. 섹션의 크기가 큰 쪽을 fill로 지정"
    근거: "SYB010.html, SYB020.html, SYD020.html, SYB030.html"

  tabbed:
    description: "탭 기반 다중 화면"
    structure:
      - area: "data-page"
        children:
          - area: "searchForm"
            id_pattern: "${PGM}searchForm"
            optional: true
          - area: "data-tab"
            id_pattern: "${PGM}tab"
            children:
              - area: "data-tab-header"
                children:
                  - area: "data-tab-header-item"
                    attributes: "data-target=\"tabName\""
              - area: "data-tab-body"
                children:
                  - area: "data-tab-body-item"
                    attributes: "data-tab=\"tabName\""
                    content: "th:insert로 탭 fragment 로드"
    근거: "DTJ010.html, DTL020.html"

  popup:
    description: "모달 팝업 화면"
    structure:
      - area: "data-page"
        children:
          - area: "toolbar"
            id_pattern: "${PGM}btnToolbar"
            optional: true
          - area: "form 또는 grid"
            id_pattern: "${PGM}postForm 또는 ${PGM}popupGrid"
    근거: "DTA030_P01.html, DTJ010_P01.html"

# -----------------------------------------------------------------------------
# CSS 클래스 규칙
# -----------------------------------------------------------------------------
css_classes:
  layout:
    - "data-page: 화면 최상위 컨테이너"
    - "data-content-wrapper: 콘텐츠 래퍼"
    - "data-content-fill: 나머지 공간 채움"
    - "data-content-2-left: 좌측 패널 (약 20%)"
    - "data-content-3-left: 좌측 패널 (약 30%)"
    - "data-content-4-right: 우측 패널 (약 20%)"
    - "data-tab: 탭 컨테이너"
    - "data-tab-header: 탭 헤더"
    - "data-tab-header-item: 탭 헤더 아이템"
    - "data-tab-body: 탭 바디"
    - "data-tab-body-item: 탭 바디 아이템"
  grid:
    - "textCenter: 텍스트 가운데 정렬"
    - "textRight: 텍스트 오른쪽 정렬"
  state:
    - "active: 활성 탭/아이템"

# -----------------------------------------------------------------------------
# DOM ID 규칙
# -----------------------------------------------------------------------------
dom_id:
  prefix: "${PGM}"
  pattern: "${PGM}{componentName}"
  mandatory: true
  reason: "같은 화면이 탭/팝업으로 다중 로드될 수 있어 ID 충돌 방지 필수"
  examples:
    - "${PGM}searchForm"
    - "${PGM}mainGrid"
    - "${PGM}btnToolbar"
    - "${PGM}tab"
    - "${PGM}detailGrid"
    - "${PGM}popupGrid"
    - "${PGM}postForm"

# -----------------------------------------------------------------------------
# 금지 레이아웃 패턴
# -----------------------------------------------------------------------------
forbidden:
  - pattern: "고정 HTML id (PGM prefix 없이)"
    reason: "다중 인스턴스 환경에서 DOM ID 충돌"
  - pattern: "frame fragment 미포함"
    reason: "top_title_button 필수"
  - pattern: "자유 HTML 구조 (data-page 외부 컨텐츠)"
    reason: "프레임워크 CSS/JS가 data-page 기반으로 동작"
  - pattern: "CSS framework 태그 직접 사용 (Bootstrap grid 등)"
    reason: "data-content-* 클래스 사용으로 통일"
  - pattern: "data-content-half-left / data-content-half-right 사용"
    reason: "균등분할이 아닌 data-content-N-left + data-content-fill 조합 사용 필수. 반드시 1개는 fill로 구성"

# -----------------------------------------------------------------------------
# v5 Rules (LR-001 ~ LR-006)
# 출처: auto_gdi_work_v5/policies/framework/layout_rules.yml
# -----------------------------------------------------------------------------
v5_rules:
  - id: LR-001
    description: "검색폼/상세폼 필드 5칸 배치 원칙"
    condition: "dataForm elements 내 cols 배열 구성 시"
    action: >
      기본적으로 한 줄에 5칸으로 배치한다.
      cols 배열은 항상 gravity 합계가 5가 되도록 구성한다.
      - 기본: cols: [{},{},{},{},{}] → 1+1+1+1+1 = 5칸
      - 2칸 필드: { gravity: 2, ... } → gravity:2 + 1 + 1 + 1 = 5
      - PPT에서 한 줄에 3칸만 사용: cols: [{},{},{},{},{}] → 3개 채우고 나머지 2개는 빈 객체 {}
      - 빈 칸은 반드시 빈 객체 {} 로 채워서 5칸을 맞춘다

      [핵심 규칙] PPT에서 같은 행(row)에 있는 필드는 반드시 하나의 cols 배열에 넣는다.
      PPT 좌표 기준으로 top이 같거나 오차 0.3cm 이내인 필드는 같은 행이다.
      절대로 같은 행의 필드를 별도 cols 배열로 분리하지 않는다.
      예: PPT에서 [연구과제명(2칸) + 검토기간(1칸)]이 한 줄이면:
        올바름: cols: [{연구과제명, gravity:2}, {검토기간}, {}, {}]  ← 한 줄, 합계 5
        잘못됨: {cols:[{연구과제명}]}, {cols:[{검토기간}]}           ← 2줄로 분리 금지
    severity: critical
    examples:
      basic: "cols: [{ view: DATA_VIEW.text, label: 'A', name: 'a' }, { view: DATA_VIEW.text, label: 'B', name: 'b' }, { view: DATA_VIEW.codeNone, ... }, { view: DATA_VIEW.date, ... }, { view: DATA_VIEW.text, ... }]"
      gravity2: "cols: [{ view: DATA_VIEW.text, label: 'A', name: 'a', gravity: 2 }, { view: DATA_VIEW.text, ... }, { view: DATA_VIEW.text, ... }, {}]"
      partial_row: "cols: [{ view: DATA_VIEW.text, ... }, { view: DATA_VIEW.codeNone, ... }, { view: DATA_VIEW.text, ... }, {}, {}]"

  - id: LR-002
    description: "레이아웃 CSS 클래스 규칙"
    condition: "HTML div 레이아웃 구성 시"
    action: >
      프레임워크 제공 레이아웃 CSS 클래스를 사용한다:
      - data-content-wrapper: flex row 컨테이너 (좌우 분할 시)
      - data-content-fill: flex:1 채움 (단일 영역)
      - data-content-half-left / data-content-half-right: 사용 금지 (LR-009 참조)
      - data-content-N-left / data-content-N-right: N칸 폭 (N * 132px)
      - data-page: 기본 페이지 컨테이너
      - data-grid: 그리드 컨테이너 (필수)
      - data-modal: 모달 컨테이너
      주의: data-content-half는 존재하지 않음. 반드시 -left 또는 -right 접미사 사용.
    severity: critical

  - id: LR-007
    description: "그리드/폼 영역 위 dataToolbar 필수"
    condition: "그리드 또는 폼 영역이 존재하는 경우"
    action: >
      조회 영역(searchForm)을 제외한 모든 그리드/폼 영역 위에는
      반드시 dataToolbar를 배치하여 해당 섹션의 title을 표시한다.
      - HTML: <div th:id="|${PGM}toolbar{N}|"></div> 를 그리드/폼 div 위에 배치
      - JS: listener.toolbar.toolbar{N} = webix.ui({ container: `${PGM}toolbar{N}`, view: 'dataToolbar', pgm: PGM, title: '섹션명' });
      - title은 PPT의 섹션 라벨(▶사전검토목록 등)에서 추출. PPT에 없으면 '작성필요'로 입력
      - initPgm 최상단에서 toolbar를 먼저 생성한 후 폼/그리드 생성
    severity: critical
    examples:
      grid: "listener.toolbar.toolbar1 = webix.ui({ container: `${PGM}toolbar1`, view: 'dataToolbar', pgm: PGM, title: '사전검토목록' });"
      form: "listener.toolbar.toolbar1 = webix.ui({ container: `${PGM}toolbar1`, view: 'dataToolbar', pgm: PGM, title: '개요' });"
    근거: "SEA010.html, SEA011.html"

  - id: LR-003
    description: "그리드 div에 data-grid 클래스 필수"
    condition: "datagrid 컨테이너 div 생성 시"
    action: >
      그리드를 담는 div에는 반드시 class="data-grid"를 추가해야 한다.
      올바름: <div class="data-grid" th:id="|${PGM}grid1|"></div>
      잘못됨: <div th:id="|${PGM}grid1|"></div>
    severity: critical
    auto_fixable: true

  - id: LR-004
    description: "편집 가능 그리드 초기 빈 행 추가"
    condition: "editable: true인 datagrid 생성 시"
    action: >
      편집 가능한 그리드(editable: true)는 initPgm에서 UI 생성 후
      gridRow.addRow()를 1회 호출하여 빈 행 1개를 미리 만들어야 한다.
      예: listener.gridRow.addRow();
    severity: critical

  - id: LR-005
    description: "data-content-wrapper 필수 구조"
    condition: "모든 화면 HTML 생성 시"
    action: >
      data-page 직접 자식으로 반드시 data-content-wrapper가 있어야 한다.
      올바름: data-page > data-content-wrapper > data-content-fill/half-left/half-right
      잘못됨: data-page > data-content-fill (wrapper 생략)
    severity: critical

  - id: LR-006
    description: "그리드 코드헬프 컬럼 editor 규칙"
    condition: "그리드 컬럼이 코드헬프(돋보기 검색)를 사용하는 경우"
    action: >
      editor: GRID_VIEW.code (NOT GRID_VIEW.text)
      type: DATA_CODE_TYPE.{코드유형} (예: user, dept, code, style 등)
      targetCols: 선택 시 자동입력할 컬럼 매핑
      예: { id: 'user_id', header: '성명', editor: GRID_VIEW.code,
            type: DATA_CODE_TYPE.user, targetCols: { dept_nm: 'dept_nm' } }
    severity: critical

  - id: LR-009
    description: "data-content-half-left / data-content-half-right 사용 금지"
    condition: "좌우 분할 레이아웃 구성 시"
    action: >
      data-content-half-left와 data-content-half-right는 사용하지 않는다.
      좌우 분할이 필요한 경우 반드시 다음 조합을 사용한다:
      - data-content-2-left + data-content-fill (좌측 약 20%, 우측 채움)
      - data-content-3-left + data-content-fill (좌측 약 30%, 우측 채움)
      - data-content-fill + data-content-4-right (좌측 채움, 우측 약 20%)
      반드시 1개는 data-content-fill로 구성하여 나머지 공간을 채워야 한다.
      섹션의 크기가 큰 쪽을 data-content-fill로 지정한다.
      주의: data-content-5-left는 실제 프레임워크에서 확인되지 않음 — 사용 금지.
    severity: critical
    auto_fixable: true

  - id: LR-010
    description: "그리드 컬럼 너비 기본값 균등분배"
    condition: "datagrid columns 구성 시"
    action: >
      PPT에서 별도의 컬럼 너비 지정이 없는 경우, 그리드 컬럼은 균등분배(fillspace: true)를 기본으로 한다.
      width를 명시적으로 지정하지 않고 fillspace: true를 사용하여 모든 컬럼이 동일 너비로 분배되도록 한다.
      단, 체크박스/행번호/짧은코드 등 명확히 좁은 컬럼은 width 고정 가능.
    severity: critical

  - id: LR-008
    description: "그리드 행번호(rowNumber) 기본값 규칙"
    condition: "datagrid 생성 시"
    action: >
      PPT에서 행번호(No) 컬럼이 명시적으로 존재하지 않으면
      rowNumber: false를 설정한다 (또는 rowNumber 속성을 생략한다).
      기본적으로 행번호는 불필요하며, PPT 설계에 명시된 경우에만 활성화한다.
    severity: critical
