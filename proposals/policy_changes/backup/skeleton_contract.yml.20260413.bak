# =============================================================================
# skeleton_contract.yml
# Skeleton Placeholder 실제 입력 계약서 (skeleton 파일 기반 보정)
# Placeholder 표기: {{placeholder_name}}
# =============================================================================

placeholder_format: "{{name}}"

# -----------------------------------------------------------------------------
# 공통 Placeholder (모든 아티팩트에서 사용)
# -----------------------------------------------------------------------------
common:
  - name: "screen_id"
    type: "string"
    description: "화면 식별자 (대문자)"
    example: "DTA030"
    required: true
    derivation: "module_id.toUpperCase()"

  - name: "screen_name"
    type: "string"
    description: "화면 한글명"
    example: "배분유형관리"
    required: true

  - name: "module_id"
    type: "string"
    description: "모듈 식별자 (소문자)"
    example: "dta030"
    required: true

  - name: "module_group"
    type: "string"
    description: "모듈 그룹"
    example: "dt"
    required: true

  - name: "sub_group"
    type: "string"
    description: "서브 그룹"
    example: "dta"
    required: true

  - name: "mapper_namespace"
    type: "string"
    description: "XML mapper namespace (= module_id)"
    example: "dta030"
    required: true
    derivation: "module_id와 동일"

# -----------------------------------------------------------------------------
# HTML 전용 Placeholder
# -----------------------------------------------------------------------------
html:
  - name: "search_fields"
    type: "array_block"
    description: "검색 폼 필드 정의 블록 (webix.ui dataForm elements 내부)"
    required: true
    item_schema:
      name: "P_ 접두사 파라미터명"
      label: "한글 레이블"
      view_type: "DATA_VIEW.*"
      code_type: "DATA_CODE_TYPE.* (선택)"
      required: "boolean"
    example_output: |
      {view: DATA_VIEW.code, label: "브랜드존", name: "P_brndz_cd", required: true, type: DATA_CODE_TYPE.brndz},
      {view: DATA_VIEW.date, label: "시작일", name: "P_start_dt"}

  - name: "grid_columns"
    type: "array_block"
    description: "그리드 컬럼 정의 블록 (webix.ui datagrid columns 내부)"
    required: true
    item_schema:
      id: "DB 컬럼명"
      header: "헤더명"
      editor: "GRID_VIEW.*"
      width: "number"
      css: "textCenter/textRight"
    example_output: |
      {id: "style_cd", header: "스타일", editor: GRID_VIEW.code, type: DATA_CODE_TYPE.style, fillspace: true, required: true},
      {id: "qty", header: "수량", editor: GRID_VIEW.text, width: 80, css: "textRight"}

  - name: "detail_fields"
    type: "array_block"
    description: "상세/편집 필드 정의 블록 (list-detail 우측, form 메인, popup 폼)"
    required_for: ["list-detail", "form", "popup"]
    optional_for: ["list"]

  - name: "action_buttons"
    type: "array_block"
    description: "툴바 버튼 정의 블록"
    required: false
    note: "기본 버튼(조회/저장/초기화)은 skeleton에 내장. 추가 버튼만 지정"

  - name: "popup_targets"
    type: "array_block"
    description: "팝업 호출 정의"
    required: false
    item_schema:
      id: "팝업 ID"
      view_path: "HTML 경로"
      width: "number"
      height: "number"
      title: "팝업 제목"

  - name: "init_script"
    type: "string_block"
    description: "추가 초기화 스크립트"
    required: false
    default: ""

  - name: "custom_button_handlers"
    type: "string_block"
    description: "커스텀 버튼 핸들러 (etc1, etc2, del 등 skeleton 기본 버튼 외)"
    required: false
    default: ""
    api_contract: |
      커스텀 버튼 핸들러 작성 시 반드시 skeleton 내 API 패턴을 따라야 한다:
      - alert: popup.alert.show(msg)
      - confirm: popup.confirm.show(msg, function(confirmYn) { if (confirmYn) { ... } })
      - 데이터 조회: listener.form.xxx.getData() / listener.grid.xxx.getCheckedData()
      - HTTP 호출: platform.post(url, param, new Callback(function(result) { ... }))
      - 화면 이동: APP_PGM.openPgm(moduleGroup, pgmId, param)
      - 화면 닫기: APP_PGM.closePgm(PGM)
      ※ platform.alert(), platform.confirm(), platform.getFormValues() 등 존재하지 않는 API 사용 절대 금지

  - name: "active_pgm_handler"
    type: "string_block"
    description: "서브화면 진입(activePgm) 핸들러 + loadDetail 함수"
    required: false
    default: ""
    api_contract: |
      activePgm/loadDetail 작성 시 반드시 다음 패턴을 따른다:
      - 폼 데이터 세팅: listener.form.xxx.setData(result.resultData)
      - readonly 전환: listener.form.xxx.setReadonly(true)
      - HTTP 콜백: new Callback(function(result) { if (result.resultCode === RESULT_CODE.OK) { ... } })
      ※ platform.setFormValues(), platform.setFormReadonly() 등 존재하지 않는 API 사용 절대 금지

  - name: "dynamic_form_control"
    type: "string_block"
    description: "동적 폼 필드 show/hide, readonly 전환 등"
    required: false
    default: ""
    api_contract: |
      동적 폼 제어 시 반드시 다음 패턴을 따른다:
      - 필드 show/hide: listener.form.xxx.getView(fieldName).show() / .hide()
      - 필드 readonly: listener.form.xxx.getView(fieldName).config.readonly = flag; .refresh()
      - 필드 값 설정: listener.form.xxx.getView(fieldName).setData(value)
      ※ platform.setFormFieldVisible(), platform.setFormFieldReadonly() 등 존재하지 않는 API 사용 절대 금지

  - name: "grid_events"
    type: "string_block"
    description: "그리드 행 클릭/더블클릭 이벤트 핸들러"
    required: false
    default: ""
    api_contract: |
      그리드 이벤트 작성 시 반드시 다음 패턴을 따른다:
      - 행 클릭: listener.gridRow.click = function(record, grid) { if (grid === listener.grid.xxx) { ... } }
      - 더블클릭: listener.gridRow.dblclick = function(row, column, record, grid) { ... }
      - 그리드 비교: grid === listener.grid.xxx (문자열 비교 금지)

# -----------------------------------------------------------------------------
# XML 전용 Placeholder
# -----------------------------------------------------------------------------
xml:
  - name: "select_sql_id"
    type: "string"
    description: "메인 목록 조회 SQL ID"
    example: "selectMainGrid"
    required: true

  - name: "detail_sql_id"
    type: "string"
    description: "상세 조회 SQL ID"
    example: "selectDetailInfo"
    required_for: ["list-detail", "form"]

  - name: "insert_sql_id"
    type: "string"
    description: "등록/수정 SQL ID"
    example: "insertData"
    required_for: ["list", "list-detail", "form"]

  - name: "delete_sql_id"
    type: "string"
    description: "삭제 SQL ID"
    example: "deleteData"
    required: false

  - name: "main_table"
    type: "string"
    description: "메인 테이블명"
    example: "sm_dstbt_tp_info"
    required: true

  - name: "detail_table"
    type: "string"
    description: "상세 테이블명"
    required_for: ["list-detail"]

  - name: "grid_columns_sql"
    type: "string_block"
    description: "SELECT 절 컬럼 나열"
    required: true

  - name: "detail_columns_sql"
    type: "string_block"
    description: "상세 SELECT 절 컬럼"
    required_for: ["list-detail", "form"]

  - name: "search_conditions_sql"
    type: "string_block"
    description: "동적 WHERE 조건 (<if> 블록)"
    required: false

  - name: "insert_columns"
    type: "string_block"
    description: "INSERT 절 컬럼 나열 (audit 제외)"
    required_for: ["list", "list-detail", "form"]

  - name: "insert_values"
    type: "string_block"
    description: "VALUES 절 (audit 제외)"
    required_for: ["list", "list-detail", "form"]

  - name: "pk_columns"
    type: "string"
    description: "ON CONFLICT PK 컬럼"
    required_for: ["list", "list-detail", "form"]

  - name: "update_set_columns"
    type: "string_block"
    description: "DO UPDATE SET 절 (audit 제외)"
    required_for: ["list", "list-detail", "form"]

  - name: "order_columns"
    type: "string"
    description: "ORDER BY 절"
    required: true

# -----------------------------------------------------------------------------
# Controller 전용 Placeholder
# -----------------------------------------------------------------------------
controller:
  - name: "controller_class"
    type: "string"
    description: "Controller 클래스명"
    example: "Dta030Controller"
    required: true
    derivation: "ModuleId + 'Controller'"

  - name: "service_class"
    type: "string"
    description: "Service 클래스명"
    example: "Dta030Service"
    required: true
    derivation: "ModuleId + 'Service'"

  - name: "service_instance"
    type: "string"
    description: "Service 인스턴스 변수명"
    example: "dta030Service"
    required: true
    derivation: "moduleId + 'Service'"

  - name: "request_base_path"
    type: "string"
    description: "@RequestMapping 기본 경로"
    example: "dta030"
    required: true
    derivation: "module_id와 동일"

  - name: "required_imports"
    type: "string_block"
    description: "추가 import 문"
    required: false
    default: ""

# -----------------------------------------------------------------------------
# Service 전용 Placeholder
# -----------------------------------------------------------------------------
service:
  - name: "service_class"
    type: "string"
    description: "Service 클래스명"
    required: true

  - name: "required_imports"
    type: "string_block"
    description: "추가 import 문"
    required: false
    default: ""

# -----------------------------------------------------------------------------
# Placeholder 누락 시 처리 규칙
# -----------------------------------------------------------------------------
missing_policy:
  required_missing: "생성 중단 + 누락 항목 보고"
  optional_missing: "해당 OPTIONAL 블록 비활성화 (제거 또는 주석 유지)"
  array_empty: "빈 블록 삽입 (// TODO: 정의 필요)"

# -----------------------------------------------------------------------------
# Screen Type별 필수 Placeholder 매트릭스
# -----------------------------------------------------------------------------
required_matrix:
  list:
    html: ["screen_id", "search_fields", "grid_columns", "mapper_namespace", "select_sql_id"]
    xml: ["mapper_namespace", "select_sql_id", "main_table", "grid_columns_sql", "order_columns"]
    controller: ["module_group", "sub_group", "module_id", "controller_class", "service_class", "service_instance", "request_base_path"]
    service: ["module_group", "sub_group", "module_id", "service_class", "mapper_namespace"]

  list_detail:
    html: ["screen_id", "search_fields", "grid_columns", "detail_fields", "mapper_namespace", "select_sql_id", "detail_sql_id", "insert_sql_id"]
    xml: ["mapper_namespace", "select_sql_id", "detail_sql_id", "insert_sql_id", "delete_sql_id", "main_table", "detail_table"]
    controller: ["module_group", "sub_group", "module_id", "controller_class", "service_class", "service_instance", "request_base_path"]
    service: ["module_group", "sub_group", "module_id", "service_class", "mapper_namespace", "insert_sql_id"]

  form:
    html: ["screen_id", "detail_fields", "mapper_namespace", "insert_sql_id"]
    xml: ["mapper_namespace", "select_sql_id", "insert_sql_id", "main_table"]
    controller: ["module_group", "sub_group", "module_id", "controller_class", "service_class", "service_instance", "request_base_path"]
    service: ["module_group", "sub_group", "module_id", "service_class", "mapper_namespace", "insert_sql_id"]

  popup:
    html: ["screen_id", "detail_fields"]
    xml: ["mapper_namespace", "select_sql_id", "main_table"]
    controller: ["module_group", "sub_group", "module_id", "controller_class", "service_class", "service_instance", "request_base_path"]
    service: ["module_group", "sub_group", "module_id", "service_class", "mapper_namespace"]

# -----------------------------------------------------------------------------
# v5 Artifact Structure Contract
# 출처: auto_gdi_work_v5/policies/framework/skeleton_contract.yml
#       auto_gdi_work_v5/policies/framework/controller_generation.yml
# -----------------------------------------------------------------------------
artifact_structure_contract:
  html:
    required_structure:
      - "IIFE wrapper"
      - "PGM declaration"
      - "listener initialization"
      - "resetState function"
      - "UI creation functions"
      - "event handlers"
      - "data operations"
      - "assign handlers block"
    validation: "all required_functions from screen-type must exist"

  xml:
    required_structure:
      - "mapper with lowercase namespace"
      - "select statements with resultType='java.util.Map'"
      - "audit columns in INSERT/UPDATE"
      - "current_timestamp usage"
    validation: "no forbidden patterns from forbidden_apis.yml"

  controller:
    generation_rule: >
      기본적으로 CommonController를 사용하므로 커스텀 Controller를 생성하지 않는다.
      policies/framework/controller_generation.yml CG-002 조건에 해당하는 경우에만 생성한다.
      HTML은 platform.url.select/save/saveAll 등 Common 엔드포인트를 사용한다.
    required_structure_when_custom:
      - "@Slf4j @Controller class extends BaseController"
      - "constructor injection (자신의 Service만 주입, CommonService는 주입하지 않음)"
      - "@AddUserInfo @ResponseBody methods (@LogAction은 선택 — 주요 데이터 변경 작업에만)"
      - "BaseResponse return type"
      - "try-catch error handling (FramePostgresException + Exception)"
    validation: "all endpoints match XML statement IDs"
    forbidden:
      - "LoginUserVo를 Controller에서 추출하여 Service에 전달하지 않음 — @AddUserInfo AOP가 자동으로 param Map에 login_* 정보를 주입"
      - "CommonService를 개별 Controller에 주입하지 않음 — 개별 Controller는 자신의 Service만 사용"

  service:
    generation_rule: >
      기본적으로 CommonService를 사용하므로 커스텀 Service를 생성하지 않는다.
      Controller와 동일한 조건(CG-002)에 해당하는 경우에만 생성한다.
    required_structure_when_custom:
      - "@Slf4j @Service class extends BaseService"
      - "SqlSessionTemplate 단일 인스턴스 (reader/writer 분리 아님)"
      - "protected 접근자 (같은 패키지 Controller에서만 호출)"
      - "@Transactional(value = \"txManager\") on write methods"
      - "namespace.statementId format for sqlSessionTemplate calls"
    forbidden:
      - "LoginUserVo를 Service 메서드 파라미터로 받지 않음 — @AddUserInfo AOP가 login_* 정보를 param Map에 이미 주입"
      - "login_comp_cd, login_user_id 등을 Service에서 수동으로 param에 put하지 않음"
      - "public 접근자 사용 금지 — protected 사용 (CommonService만 public)"
    validation: "all write methods have @Transactional(value = 'txManager')"

  sql:
    audit_columns:
      insert:
        - firs_reg_pgm_id
        - firs_reg_dts
        - firs_reg_user_id
        - firs_reg_ip
        - fina_reg_pgm_id
        - fina_reg_dts
        - fina_reg_user_id
        - fina_reg_ip
      update:
        - fina_reg_pgm_id
        - fina_reg_dts
        - fina_reg_user_id
        - fina_reg_ip
      naming_rule: >
        감사컬럼명은 DDL에 정의된 이름을 그대로 사용한다.
        에이전트가 약어를 추론하여 변형하는 것을 금지한다.
        정확한 접두사: firs_reg (O), fina_reg (O)
        금지 변형: frst_reg (X), first_reg (X), fist_reg (X), fnl_reg (X)
    menu_registration:
      menu_id_pattern: "CTE + COALESCE(existing pgm_id lookup, MAX+1) — 하드코딩 금지"
      required: true
      condition: "sy_menu_info INSERT 생성 시"
    validation: "all audit column names must match DDL exactly"

  rules:
    - id: SC-001
      description: "skeleton 미사용 시 생성 거부"
      condition: "generate without skeleton"
      action: "block generation, require skeleton selection"
      severity: critical

    - id: SC-002
      description: "감사컬럼명 DDL 원문 사용 강제"
      condition: "SQL generation with audit columns"
      action: "use exact column names from contracts.sql.audit_columns, never infer abbreviations"
      severity: critical

    - id: CG-001
      description: "CommonController 우선 사용 원칙"
      condition: "모든 화면 생성 시"
      action: >
        기본적으로 CommonController/CommonService를 사용한다.
        HTML에서 platform.url.select, platform.url.save, platform.url.saveAll 등
        표준 엔드포인트를 호출하며, statement 파라미터로 XML mapper를 지정한다.
        커스텀 Controller/Service는 생성하지 않는 것이 기본이다.
      severity: critical

    - id: CG-002
      description: "커스텀 Controller/Service 생성 조건"
      condition: "아래 조건 중 하나 이상 해당 시에만 커스텀 생성"
      action: >
        커스텀 Controller/Service가 필요한 경우:
        1. 암호화/복호화 처리 (FrameCubeOneUtil 등)
        2. 복잡한 비즈니스 로직 (조건부 분기 INSERT/UPDATE, 계산 로직)
        3. 외부 API 연동
        4. 파일 업로드/다운로드 (CommonController 파일 기능으로 불충분한 경우)
        5. 프로시저 호출 후 추가 가공
        6. 트랜잭션 내 다중 테이블 조건부 처리 (단순 saveAll로 불가능한 경우)
        7. 기능정의서에 명시적으로 "커스텀 로직 필요"로 태깅된 경우
      severity: critical

    - id: CG-003
      description: "커스텀 Controller/Service 불필요 판단 기준"
      condition: "아래 조건 모두 해당 시 Common 사용"
      action: >
        CommonController로 충분한 경우 (커스텀 생성 금지):
        1. 단순 SELECT (단건/다건/페이징)
        2. 단순 INSERT/UPDATE/DELETE (단일 statement)
        3. 다건 저장 (saveAll — 복수 statement를 Param.add로 전달)
        4. 코드헬프 조회
        5. 상태 체크 후 저장/삭제 차단 (이 로직은 HTML에서 처리)
        위 경우 모두 platform.url.* 표준 엔드포인트 + statement 파라미터로 처리 가능
      severity: critical
