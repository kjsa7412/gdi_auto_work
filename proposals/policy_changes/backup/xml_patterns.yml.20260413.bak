# =============================================================================
# xml_patterns.yml
# XML Mapper 패턴 분석 결과
# 근거: FERP dt 모듈 97개 XML mapper 전수 분석
# =============================================================================

# -----------------------------------------------------------------------------
# Mapper Namespace 규칙
# -----------------------------------------------------------------------------
namespace:
  pattern: "{module_id}"
  case: "소문자"
  rule: "1 파일 = 1 namespace = 모듈ID"
  examples:
    - "<mapper namespace=\"dta030\">"
    - "<mapper namespace=\"dtb010\">"
    - "<mapper namespace=\"common\">"
  doctype: "<!DOCTYPE mapper PUBLIC \"-//mybatis.org//DTD Mapper 3.0//EN\" \"http://mybatis.org/dtd/mybatis-3-mapper.dtd\">"
  근거: "97개 XML 파일 전수 확인"

# -----------------------------------------------------------------------------
# SQL ID 규칙
# -----------------------------------------------------------------------------
sql_id:
  select:
    patterns:
      - "select{Subject}"
      - "select{Subject}List"
      - "select{Subject}Grid"
      - "selectMainGrid"
      - "select{Subject}Info"
      - "select{Subject}Count"  # 페이징용 카운트
    examples:
      - "selectDstbtPrdt"
      - "selectStyleColrInfo"
      - "selectCommPrdtStdDtInfo"
      - "selectMainGrid"
      - "selectAssortGrid"
  insert:
    patterns:
      - "insert{Subject}"
      - "insertData"
    examples:
      - "insertProdtStdDtInfo"
      - "insertData"
      - "insertBrndAutoDstbtSetu"
  update:
    patterns:
      - "update{Subject}"
    examples:
      - "updateSizeMovPnltyIndcDtl"
      - "updateDtSizeMovStdShopInfo"
  delete:
    patterns:
      - "delete{Subject}"
    examples:
      - "deleteProdtStdDtInfo"
      - "deleteDstbt"

# -----------------------------------------------------------------------------
# parameterType / resultType
# -----------------------------------------------------------------------------
type_usage:
  resultType:
    primary: "java.util.Map"
    alternatives:
      - "String"
      - "Integer"
    description: "거의 모든 조회가 java.util.Map 반환"
  parameterType:
    description: "명시하지 않음. MyBatis가 자동 매핑"
    rule: "parameterType 속성 생략이 표준"
  근거: "97개 XML에서 resultType=\"java.util.Map\" 지배적"

# -----------------------------------------------------------------------------
# 동적 조건 처리 방식
# -----------------------------------------------------------------------------
dynamic_sql:
  if_condition:
    pattern: "<if test=\"{param} != null and {param} != ''\">"
    examples:
      - "<if test=\"P_brndz_cd != null and P_brndz_cd != ''\">and a.brndz_cd = #{P_brndz_cd}</if>"
      - "<if test=\"P_start_dt != null and P_start_dt != ''\">and a.dstbt_dt >= replace(#{P_start_dt},'-','')</if>"
    description: "null과 빈 문자열을 모두 체크하는 것이 표준"

  choose_when:
    pattern: "<choose><when test=\"condition\">...</when><otherwise>...</otherwise></choose>"
    usage: "조건에 따라 다른 SQL 분기"

  foreach:
    pattern: "<foreach collection=\"{listParam}\" item=\"item\" separator=\",\" open=\"(\" close=\")\">"
    examples:
      - "IN 절: <foreach collection=\"P_oprt_gb\" item=\"item\" open=\"and a.oprt_tp in (\" close=\")\" separator=\",\">#{item}</foreach>"
      - "UNION ALL: <foreach collection=\"reqList\" item=\"r\" separator=\"union all\">select ...</foreach>"
    usage:
      - "IN 절 생성"
      - "UNION ALL 일괄 insert"
      - "VALUES 절 반복"

  cdata:
    pattern: "<![CDATA[<=]]>"
    usage: "XML에서 <, >, <= 등 특수문자 이스케이프"
    examples:
      - "and a.dstbt_dt <![CDATA[<=]]> replace(#{P_dstbt_dt},'-','')"

# -----------------------------------------------------------------------------
# 공통 SQL 조각 사용 여부
# -----------------------------------------------------------------------------
sql_fragments:
  description: "별도 <sql> 태그를 통한 공통 조각 재사용은 확인되지 않음"

# -----------------------------------------------------------------------------
# 감사(Audit) 컬럼 규칙 — 모든 INSERT/UPDATE에 필수
# -----------------------------------------------------------------------------
audit_columns:
  id: AUD-001
  description: >
    아래 8개 컬럼은 테이블 공통 컬럼이다.
    INSERT/UPDATE 쿼리 작성 시 반드시 포함해야 한다.
  severity: critical

  columns:
    - firs_reg_pgm_id   # 최초등록프로그램ID
    - firs_reg_dts      # 최초등록일시
    - firs_reg_user_id  # 최초등록자ID
    - firs_reg_ip       # 최초등록IP
    - fina_reg_pgm_id   # 최종등록프로그램ID
    - fina_reg_dts      # 최종등록일시
    - fina_reg_user_id  # 최종등록자ID
    - fina_reg_ip       # 최종등록IP

  insert_rule:
    id: AUD-002
    description: "INSERT 시 8개 전부 포함. firs_reg_*는 최초 1회 기록, fina_reg_*도 최초값과 동일하게 기록"
    columns: |
      firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip,
      fina_reg_pgm_id, fina_reg_dts, fina_reg_user_id, fina_reg_ip
    values: |
      #{reg_pgm_id}, now(), #{login_emp_no}, #{login_user_ip},
      #{reg_pgm_id}, now(), #{login_emp_no}, #{login_user_ip}
    binding:
      firs_reg_pgm_id: "#{reg_pgm_id}"
      firs_reg_dts: "now()"
      firs_reg_user_id: "#{login_emp_no}"
      firs_reg_ip: "#{login_user_ip}"
      fina_reg_pgm_id: "#{reg_pgm_id}"
      fina_reg_dts: "now()"
      fina_reg_user_id: "#{login_emp_no}"
      fina_reg_ip: "#{login_user_ip}"

  update_rule:
    id: AUD-003
    description: "UPDATE 시 fina_reg_* 4개만 갱신. firs_reg_*는 절대 수정하지 않는다 (최초 등록 정보 보존)"
    set_clause: |
      fina_reg_pgm_id = #{reg_pgm_id},
      fina_reg_dts = now(),
      fina_reg_user_id = #{login_emp_no},
      fina_reg_ip = #{login_user_ip}
    binding:
      fina_reg_pgm_id: "#{reg_pgm_id}"
      fina_reg_dts: "now()"
      fina_reg_user_id: "#{login_emp_no}"
      fina_reg_ip: "#{login_user_ip}"
    forbidden: "UPDATE SET에서 firs_reg_* 컬럼 수정 금지"

  upsert_on_conflict_rule:
    id: AUD-004
    description: "ON CONFLICT DO UPDATE 시 fina_reg_* 4개만 갱신"
    set_clause: |
      fina_reg_pgm_id = #{reg_pgm_id},
      fina_reg_dts = now(),
      fina_reg_user_id = #{login_user_id},
      fina_reg_ip = #{login_user_ip}
    note: "직접 #{} 바인딩 사용. excluded.firs_reg_*는 일부 코드에서 사용하나 #{} 직접 바인딩이 표준"

# -----------------------------------------------------------------------------
# PK 채번 규칙 — 모든 INSERT의 PK 값 생성 (PP-20260410-001)
# -----------------------------------------------------------------------------
pk_generation:
  id: PK-001
  description: >
    별도의 요청이 없는 한, 모든 테이블의 PK 채번은 fn_sy_get_seq 함수를 사용한다.
    INSERT 시 PK 값 자리에 서브쿼리로 채번 SQL을 삽입한다.
  severity: critical

  default_pattern:
    description: "공통 테이블의 PK 채번 (seq_type: '01')"
    sql: >
      (SELECT TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || LPAD(fn_sy_get_seq('01',
      TO_CHAR(CURRENT_DATE, 'YYYYMMDD'), null, null, null, null,
      #{reg_pgm_id}, #{login_user_id}, #{login_user_ip})::varchar, 8, '0'))
    applies_to: "모든 테이블 (특수 규칙에 해당하지 않는 경우)"

  special_patterns:
    - table: "rp_rsch_prj_mst"
      pk_column: "rsch_prj_id"
      seq_type: "'02'"
      description: "연구과제 마스터 전용 채번"
      sql: >
        (SELECT TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || LPAD(fn_sy_get_seq('02',
        TO_CHAR(CURRENT_DATE, 'YYYYMMDD'), null, null, null, null,
        #{reg_pgm_id}, #{login_user_id}, #{login_user_ip})::varchar, 8, '0'))

  rules:
    - "INSERT의 PK VALUES 자리에 채번 서브쿼리를 삽입한다"
    - "ON CONFLICT (pk) DO UPDATE 패턴에서는 신규 INSERT 시에만 채번된다"
    - "seq_type이 지정되지 않은 테이블은 기본값 '01'을 사용한다"
    - "fn_sy_get_seq 함수는 DB에 존재하며 integer를 반환한다"
    - "교차 참조 테이블은 PK-002 사전채번 패턴을 사용한다"
    - "wrk_mast_id 공통 구조는 PK-003 규칙을 따른다"

# -----------------------------------------------------------------------------
# wrk_mast_id 공통 테이블 구조 규칙 (PP-20260410-002)
# -----------------------------------------------------------------------------
wrk_mast_id_pattern:
  id: PK-003
  description: >
    모든 rp_ 테이블은 wrk_mast_id를 첫 번째 컬럼(PK 구성요소)으로 갖는다.
    이것은 GDI 프레임워크의 공통 테이블 설계 패턴이다.
  severity: critical

  structure:
    description: "rp_ 테이블의 PK 구조 유형"
    types:
      - type: "단독 마스터"
        pk: "wrk_mast_id 단독"
        채번: "fn_sy_get_seq seq_type '01'"
        examples: ["rp_prj_rcpt_mst", "rp_pre_rview_mst", "rp_rpmc_insp_mst", "rp_rdc_mst"]

      - type: "도메인 마스터 (wrk_mast_id = domain_id)"
        pk: "(wrk_mast_id, domain_id) — 두 컬럼이 동일한 값"
        채번: "fn_sy_get_seq 도메인 전용 seq_type ('02' 등) 하나만 채번, 양쪽에 동일 값"
        examples: ["rp_rsch_prj_mst (wrk_mast_id = rsch_prj_id, seq '02')"]
        rule: >
          PK가 (wrk_mast_id, domain_id)이고 두 값이 동일한 경우,
          채번은 한 번만 하고 INSERT에서 양쪽 컬럼에 같은 값을 넣는다.
          예: VALUES (#{rsch_prj_id}, #{rsch_prj_id}, ...)

      - type: "디테일/자식"
        pk: "(wrk_mast_id, 부모_key, ...) — 복합 PK"
        채번: "wrk_mast_id는 부모에서 전달 (#{wrk_mast_id})"
        examples:
          - "rp_pre_rview_opl_list (wrk_mast_id, rview_targr_id, rsch_prj_id)"
          - "rp_rpmc_insp_prj_list (wrk_mast_id, rsch_prj_id)"
          - "rp_rpmc_insp_targr_list (wrk_mast_id, insp_targr_id)"
          - "rp_rpmc_insp_evl_list (wrk_mast_id, insp_targr_id, rsch_prj_id)"

  판정_규칙:
    - "cache table.txt에서 PK 구조를 확인한다"
    - "PK가 (wrk_mast_id, X_id) 형태이고 X가 해당 테이블의 도메인 엔티티명이면 → 동일값 패턴"
    - "PK가 wrk_mast_id 단독이면 → 단독 마스터"
    - "PK에 wrk_mast_id + 외부 참조 키가 있으면 → 디테일/자식"

pk_pre_generation:
  id: PK-002
  description: >
    두 테이블이 서로의 PK를 참조하는 교차 참조 구조에서는 PK를 사전 채번하여
    양쪽 INSERT에 동일 값을 전달한다. saveAll로 한 트랜잭션에서 실행하되,
    INSERT 서브쿼리 대신 #{pk_column} 파라미터 바인딩을 사용한다.
  severity: critical
  trigger_condition: >
    테이블 A의 INSERT에 테이블 B의 PK가 필요하고, 동시에 테이블 B의 INSERT에
    테이블 A의 PK가 필요한 경우 (교차 참조 / 상호 FK 관계).
    예: rp_rsch_prj_mst(rsch_prj_id) ↔ rp_prj_rcpt_mst(wrk_mast_id)

  implementation:
    xml:
      - step: 1
        action: "selectNewKeys SQL 추가"
        description: >
          필요한 PK들을 한 번의 SELECT로 사전 채번하는 SQL을 작성한다.
          각 PK별 fn_sy_get_seq를 호출하여 결과를 AS alias로 반환한다.
        example: |
          <select id="selectNewKeys" resultType="java.util.Map">
              SELECT
                  TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || LPAD(fn_sy_get_seq('01', ...)::varchar, 8, '0') AS wrk_mast_id,
                  TO_CHAR(CURRENT_DATE, 'YYYYMMDD') || LPAD(fn_sy_get_seq('02', ...)::varchar, 8, '0') AS rsch_prj_id
          </select>

      - step: 2
        action: "INSERT에서 서브쿼리 제거 → #{pk} 바인딩으로 변경"
        description: >
          insertA, insertB 양쪽 모두 PK VALUES에서 fn_sy_get_seq 서브쿼리를 제거하고,
          #{wrk_mast_id}, #{rsch_prj_id} 등 파라미터 바인딩으로 교체한다.
          ON CONFLICT DO UPDATE는 기존 패턴 유지.

    html:
      - step: 3
        action: "신규 저장 시 selectNewKeys 선행 호출"
        description: >
          formData에 PK가 없으면(신규) selectNewKeys를 먼저 호출하여
          생성된 키 값을 formData에 세팅한 후 saveAll을 실행한다.
          기존 레코드 수정 시(PK 존재)는 selectNewKeys를 건너뛴다.
        pattern: |
          if (!formData.pk_column) {
              formData.statement = "namespace.selectNewKeys";
              platform.post(platform.url.selectOne, formData, new Callback(function (keyResult) {
                  formData.pk1 = keyResult.resultData.pk1;
                  formData.pk2 = keyResult.resultData.pk2;
                  delete formData.statement;
                  doSave();
              }));
          } else {
              doSave();
          }

  applied_cases:
    - tables: ["rp_rsch_prj_mst", "rp_prj_rcpt_mst"]
      screens: ["SEA011", "SEA021"]
      keys: {wrk_mast_id: "seq '01'", rsch_prj_id: "seq '02'"}

# -----------------------------------------------------------------------------
# 페이징/정렬 규칙
# -----------------------------------------------------------------------------
paging:
  method: "OFFSET/LIMIT 방식"
  parameters:
    page_no: "P_page_no"
    page_size: "P_page_size"
    start_row: "startRow"
    end_row: "endRow"
  count_query: "원본 sqlId + 'Count' 접미사 (예: selectMainGridCount)"
  pattern: |
    OFFSET (#{P_page_no} - 1) * #{P_page_size}
    LIMIT #{P_page_size}
  근거: "CommonController.selectListPager()"

sorting:
  method: "ORDER BY 하드코딩"
  description: "정렬은 SQL에 직접 기술. 동적 정렬 파라미터 미사용"
  typical_columns: "3~8개 컬럼 복합 정렬"

# -----------------------------------------------------------------------------
# 코드 컬럼 조회/저장 규칙 (PP-20260410-003)
# -----------------------------------------------------------------------------
code_column_rules:
  id: CODE-001
  description: >
    코드 컬럼(공통코드를 참조하는 컬럼)은 저장 시 코드 ID만 저장하고,
    조회(SELECT) 시 코드 ID와 함께 fn_sy_get_code_nm으로 코드명을 가져온다.
  severity: critical

  save_rule:
    description: "INSERT/UPDATE 시 코드 컬럼에는 코드 ID(comm_cd)만 저장"
    example: "#{rsch_ctg_cd} — 코드 ID 값만 바인딩"
    cd_only_rule:
      id: CODE-002
      description: >
        코드 저장 시 wrk_tp_cd + cd_tp_cd + comm_cd 전체(예: 'RP060010')가 아닌,
        comm_cd 부분(예: '010')만 저장한다.
        화면에서 전체 코드('RP060010')로 지시하더라도 comm_cd('010')만 추출하여 저장한다.
      severity: critical
      rule: >
        코드 컬럼의 DB 저장값은 반드시 comm_cd (코드 ID) 부분만 저장한다.
        예: prgrs_stat_cd = '010' (O), prgrs_stat_cd = 'RP060010' (X)
      extraction: >
        전체코드 'RP060010'에서 comm_cd 추출 방법:
        - wrk_tp_cd(2자리) + cd_tp_cd(3자리) + comm_cd(나머지)
        - 즉, 앞 5자리를 제거한 나머지가 comm_cd
        - 예: 'RP060010' → comm_cd = '010', 'RP040020' → comm_cd = '020'
      hardcoded_comparison: >
        SQL WHERE 절이나 JS 비교에서도 comm_cd만 사용한다.
        예: AND a.prgrs_stat_cd = '020' (O), AND a.prgrs_stat_cd = 'RP060020' (X)
        예: if (item.prgrs_stat_cd === '020') (O), if (item.prgrs_stat_cd === 'RP060020') (X)
      forbidden: "DB 저장값이나 비교값에 wrk_tp_cd+cd_tp_cd 접두사를 포함하는 것"

  select_rule:
    description: "SELECT 시 코드 ID 컬럼 + fn_sy_get_code_nm()으로 코드명 병행 조회"
    function: "fn_sy_get_code_nm(wrk_tp_cd, cd_tp_cd, comm_cd)"
    alias_pattern: "{column_name}_nm"
    example: |
      a.rsch_ctg_cd,
      fn_sy_get_code_nm('SE', 'RP010', a.rsch_ctg_cd) AS rsch_ctg_cd_nm
    note: >
      wrk_tp_cd와 cd_tp_cd는 cache code.txt 또는 table.txt 컬럼 주석에서 확인.
      테이블 주석에 '| RP010' 형태로 코드그룹이 표기된 경우 해당 값 사용.

  코드그룹_식별:
    description: "table.txt 컬럼 주석에 '| XX000' 형태로 코드그룹이 명시된 경우 해당 코드그룹 사용"
    example: "prgrs_stat_cd | RP040 → wrk_tp_cd='SE', cd_tp_cd='RP040'"
    wrk_tp_cd_규칙: "업무구분코드. SE 모듈이면 'SE', DT 모듈이면 'DT'"

  적용_대상:
    - "그리드 목록 조회 (selectMainGrid 등)"
    - "상세 조회 (selectData 등)"
    - "팝업/코드헬프 결과에서 코드명 표출이 필요한 경우"

# -----------------------------------------------------------------------------
# 목록/상세/저장 쿼리 패턴
# -----------------------------------------------------------------------------
query_patterns:

  list_query:
    description: "목록 조회"
    features:
      - "다중 LEFT OUTER JOIN"
      - "fn_*() 함수 호출로 코드명 변환"
      - "P_ 접두사 검색 조건"
      - "comp_cd WHERE 조건은 테이블에 comp_cd 컬럼이 실제로 존재하는 경우에만 추가. cache table.txt에서 확인 후 적용. rp_*, ct_*, se_* 등 대부분의 업무 테이블은 comp_cd가 없으므로 생략"
      - "ORDER BY 다중 컬럼"
    example_functions:
      - "fn_ps_get_brndz_nm(a.comp_cd, a.brndz_cd) as brndz_cd_nm"
      - "fn_sy_get_code_nm(a.comp_cd, 'PS', '080', a.colr_cd) as colr_nm"
      - "fn_ss_get_shop_nm(a.comp_cd, a.brndz_cd, a.shop_cd) as shop_nm"
    근거: "dta010.xml, dta020.xml, dtb010.xml"

  detail_query:
    description: "단건 상세 조회"
    features:
      - "WHERE 절에 PK 조건 직접 지정"
      - "resultType=\"java.util.Map\""

  upsert_query:
    description: "PostgreSQL ON CONFLICT 또는 WITH UPSERT"
    patterns:
      on_conflict: |
        INSERT INTO {table} ({columns},
            firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip,
            fina_reg_pgm_id, fina_reg_dts, fina_reg_user_id, fina_reg_ip)
        VALUES ({values},
            #{reg_pgm_id}, now(), #{login_user_id}, #{login_user_ip},
            #{reg_pgm_id}, now(), #{login_user_id}, #{login_user_ip})
        ON CONFLICT ({pk_columns})
        DO UPDATE SET
            {column} = EXCLUDED.{column},
            fina_reg_pgm_id = #{reg_pgm_id},
            fina_reg_dts = now(),
            fina_reg_user_id = #{login_user_id},
            fina_reg_ip = #{login_user_ip}
      with_upsert: |
        WITH sdata AS (
        UPDATE {table}
        SET {column} = #{column}, ...,
            fina_reg_pgm_id = #{reg_pgm_id},
            fina_reg_dts = current_timestamp,
            fina_reg_user_id = #{login_user_id},
            fina_reg_ip = #{login_user_ip}
        WHERE {pk_conditions}
        RETURNING *
        )
        INSERT INTO {table} ({columns},
            firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip)
        SELECT {values},
            #{reg_pgm_id}, current_timestamp, #{login_user_id}, #{login_user_ip}
        WHERE NOT EXISTS (SELECT * FROM sdata)
    features:
      - "ON CONFLICT: PK 충돌 시 자동 UPDATE (seb011.xml 패턴)"
      - "WITH UPSERT: UPDATE 먼저 시도, 없으면 INSERT (syc010.xml 패턴)"
      - "allow_update 동적 플래그 사용하지 않음 — UPSERT는 항상 적용 또는 별도 INSERT/UPDATE 분리"
      - "ON CONFLICT DO UPDATE에서 audit 컬럼은 #{reg_pgm_id} 직접 바인딩 (excluded 미사용)"
    근거: "syc010.xml(WITH), seb011.xml(ON CONFLICT), syd020.xml(FOREACH+WITH)"

  delete_insert_pattern:
    description: "DELETE 후 INSERT (데이터 교체)"
    pattern: |
      <insert id="insertData">
          DELETE FROM {table} WHERE {conditions};
          INSERT INTO {table} ({columns}) VALUES ({values})
          ON CONFLICT ({pk_columns}) DO UPDATE SET ...
      </insert>
    근거: "dta030.xml - insertData"

  procedure_call:
    description: "저장 프로시저 호출"
    pattern: |
      <insert id="procedureName">
          CALL sp_{procedure_name}(#{param1}, #{param2}, ...)
      </insert>
    근거: "dta030.xml - dstbtPrdtAutoCrt: CALL sp_dstbt_prdt_auto_crt()"

# -----------------------------------------------------------------------------
# 코드/공통테이블 참조 방식
# -----------------------------------------------------------------------------
code_reference:
  code_master:
    table: "sy_code_mst"
    description: "코드 유형 마스터"
  code_detail:
    table: "sy_code_dtl"
    description: "코드 상세. 반드시 sy_code_dtl 테이블명 사용 (sy_comm_cd 등 변형 금지)"
    subquery_pattern: "(SELECT comm_cd_nm FROM sy_code_dtl WHERE wrk_tp_cd = '{wrk}' AND cd_tp_cd = '{cd}' AND comm_cd = {column}) AS {alias}"
    join_pattern: "LEFT OUTER JOIN sy_code_dtl ON wrk_tp_cd = ? AND cd_tp_cd = ? AND comm_cd = ?"
    note: "comp_cd 없는 테이블에서는 comp_cd 조건 생략"
  code_function:
    pattern: "fn_sy_get_code_nm(comp_cd, wrk_tp_cd, cd_tp_cd, cd)"
    description: "스칼라 함수로 코드명 조회 (comp_cd 있는 테이블용)"
  근거: "sea010.xml, sea011.xml, dta010.xml, dta020.xml, dtb010.xml"

# -----------------------------------------------------------------------------
# PostgreSQL 특화 패턴
# -----------------------------------------------------------------------------
postgresql_specific:
  type_casting:
    - "::bigint"
    - "::NUMERIC"
    - "::NUMERIC(6,2)"
    - "::text"
  upsert: "ON CONFLICT ... DO UPDATE SET"
  lateral_join: "CROSS JOIN LATERAL"
  string_agg: "STRING_AGG()"
  cte: "WITH ... AS (...)"
  coalesce: "COALESCE()"
  date_functions:
    - "now()"
    - "replace(#{date_param}, '-', '')"
    - "to_date()"

# -----------------------------------------------------------------------------
# Naming Convention
# -----------------------------------------------------------------------------
naming:
  parameter_prefix:
    search: "P_"
    login: "login_"
    master_grid: "M_"
    foreach_item: "r.*, item.*"
  column_naming: "snake_case 소문자"
  alias: "a, b, c... 순차 알파벳"

# -----------------------------------------------------------------------------
# 금지 SQL 작성 방식
# -----------------------------------------------------------------------------
forbidden:
  - pattern: "SELECT *"
    reason: "명시적 컬럼 열거 필수"
  - pattern: "DDL 문 (CREATE, ALTER, DROP)"
    reason: "Mapper에서 DDL 금지. DBA 관리 영역"
  - pattern: "INSERT/UPDATE/DELETE 문에서 parameterType 명시"
    reason: "MyBatis 자동 매핑 사용"
  - pattern: "동적 테이블명/컬럼명 (${})"
    reason: "SQL Injection 위험. #{} 만 사용"
  - pattern: "comp_cd 컬럼이 있는 테이블에서 login_comp_cd 없는 WHERE 절"
    reason: "comp_cd 컬럼이 있는 테이블은 멀티 회사 체계에서 comp_cd 필터링 필수. 단, comp_cd 컬럼이 없는 테이블(rp_*, ct_*, se_* 등 대부분의 업무 테이블)은 comp_cd 조건을 추가하지 않는다. cache table.txt에서 반드시 확인 후 적용"
  - pattern: "INSERT에서 audit 컬럼 누락"
    reason: "firs_reg_* 4개 + fina_reg_* 4개 = 8개 컬럼 INSERT 시 필수 (AUD-002)"
  - pattern: "UPDATE에서 fina_reg_* 누락"
    reason: "UPDATE SET에 fina_reg_pgm_id, fina_reg_dts, fina_reg_user_id, fina_reg_ip 필수 (AUD-003)"
  - pattern: "UPDATE에서 firs_reg_* 수정"
    reason: "firs_reg_*는 최초 등록 정보. UPDATE에서 절대 변경 금지 (AUD-003)"
