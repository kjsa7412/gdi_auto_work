{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analyze_manifest.schema.json",
  "title": "Analyze Manifest",
  "description": "Schema for analyze.manifest.yml",
  "type": "object",
  "required": ["version", "status", "inputs", "outputs", "screens", "started_at", "completed_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "inputs": {
      "type": "object",
      "required": ["prep_files"],
      "additionalProperties": false,
      "properties": {
        "prep_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["people_spec_original", "machine_spec_original", "people_spec_final"],
      "additionalProperties": false,
      "properties": {
        "people_spec_original": {
          "type": "string",
          "description": "Path to the original people spec"
        },
        "machine_spec_original": {
          "type": "string",
          "description": "Path to the original machine spec"
        },
        "people_spec_final": {
          "type": "string",
          "description": "Path to the finalized people spec"
        }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["screen_id", "screen_name", "screen_type", "confidence"],
        "additionalProperties": false,
        "properties": {
          "screen_id": {
            "type": "string",
            "minLength": 1
          },
          "screen_name": {
            "type": "string",
            "minLength": 1
          },
          "screen_type": {
            "type": "string",
            "enum": ["list", "list-detail", "form", "popup"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cache": {
      "type": "object",
      "properties": {
        "refresh_attempted": {"type": "boolean"},
        "refresh_required": {"type": "boolean"},
        "refresh_status": {"type": "string", "enum": ["success", "partial", "failed", "skipped"]},
        "refreshed_files": {"type": "array", "items": {"type": "string"}},
        "refresh_started_at": {"type": ["string", "null"]},
        "refresh_completed_at": {"type": ["string", "null"]},
        "db_fallback_used": {"type": "boolean"}
      }
    }
  }
}
