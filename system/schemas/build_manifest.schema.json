{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "build_manifest.schema.json",
  "title": "Build Manifest",
  "description": "Schema for build.manifest.yml",
  "type": "object",
  "required": ["version", "status", "inputs", "outputs", "selected_templates", "artifact_plan", "started_at", "completed_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "inputs": {
      "type": "object",
      "required": ["people_spec_original", "people_spec_final", "machine_spec_original"],
      "additionalProperties": false,
      "properties": {
        "people_spec_original": { "type": "string" },
        "people_spec_final": { "type": "string" },
        "machine_spec_original": { "type": "string" }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["machine_spec_final", "generated_paths", "deliverables_path", "report_path"],
      "additionalProperties": false,
      "properties": {
        "machine_spec_final": { "type": "string" },
        "generated_paths": { "type": "array", "items": { "type": "string" } },
        "deliverables_path": { "type": "string" },
        "report_path": { "type": "string" }
      }
    },
    "review_summary": {
      "type": "object",
      "description": "review skill diff 요약",
      "properties": {
        "changed_search_fields": { "type": "integer" },
        "changed_grid_columns": { "type": "integer" },
        "changed_detail_fields": { "type": "integer" },
        "changed_buttons": { "type": "integer" },
        "screen_type_changed": { "type": "boolean" },
        "total_changes": { "type": "integer" }
      }
    },
    "selected_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact_type": { "type": "string" },
          "template_path": { "type": "string" },
          "skeleton_path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifact_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact_type": { "type": "string" },
          "target_path": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "generated", "skipped", "failed"] }
        },
        "additionalProperties": false
      }
    },
    "verify": {
      "type": "object",
      "description": "verify 정책 기반 검증 결과 요약",
      "properties": {
        "critical_pass": { "type": "boolean" },
        "auto_fixed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manual_required": { "type": "boolean" },
        "details": {
          "type": "object",
          "properties": {
            "html_checks": { "$ref": "#/$defs/check_count" },
            "xml_checks": { "$ref": "#/$defs/check_count" },
            "sql_checks": { "$ref": "#/$defs/check_count" },
            "controller_checks": { "$ref": "#/$defs/check_count" },
            "service_checks": { "$ref": "#/$defs/check_count" }
          }
        },
        "self_diagnosis": {
          "type": "object",
          "properties": {
            "ddl_supplements": { "type": "array", "items": { "type": "string" } },
            "code_registrations": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] }
        },
        "additionalProperties": false
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "used": {"type": "boolean"},
        "hit_categories": {"type": "array", "items": {"type": "string"}},
        "miss_categories": {"type": "array", "items": {"type": "string"}},
        "insufficient": {"type": "boolean"},
        "mismatch_detected": {"type": "boolean"},
        "db_fallback_used": {"type": "boolean"},
        "db_fallback_reason": {"type": "array", "items": {"type": "string"}},
        "db_fallback_status": {"type": ["string", "null"], "enum": ["success", "partial", "failed", null]}
      }
    },
    "deploy": {
      "type": "object",
      "description": "선택적 deploy 준비 결과. deploy는 build 필수 성공 조건이 아님",
      "properties": {
        "attempted": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["prepare-only", "apply"] },
        "status": { "type": "string", "enum": ["prepared", "warn", "failed", "skipped", "applied", "partial"] },
        "summary_path": { "type": ["string", "null"] },
        "total_files": { "type": "integer" },
        "target_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {"type": "string"},
              "target": {"type": "string"},
              "status": {"type": "string", "enum": ["ready", "conflict", "path_unknown", "copied", "skipped", "failed"]}
            },
            "additionalProperties": false
          }
        },
        "warnings": { "type": "array", "items": {"type": "string"} },
        "conflicts": { "type": "array", "items": {"type": "string"} }
      }
    }
  },
  "$defs": {
    "check_count": {
      "type": "object",
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "warnings": { "type": "integer" }
      }
    }
  }
}