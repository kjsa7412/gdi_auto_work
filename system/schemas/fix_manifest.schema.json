{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fix_manifest.schema.json",
  "title": "Fix Manifest",
  "description": "Schema for fix.manifest.yml",
  "type": "object",
  "required": ["version", "status", "input_fix_file", "issue_type", "impact_scope", "actions_taken", "started_at", "completed_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "input_fix_file": {
      "type": "string",
      "description": "Path to the input fix request file"
    },
    "issue_type": {
      "type": "string",
      "enum": ["output_patch", "skeleton_patch", "reanalyze", "rebuild", "policy_patch"],
      "description": "issue_classification.yml 기준 오류 유형"
    },
    "impact_scope": {
      "type": "object",
      "required": ["reanalyze_required", "rebuild_required", "policy_patch_required", "affected_paths"],
      "additionalProperties": false,
      "properties": {
        "reanalyze_required": {
          "type": "boolean"
        },
        "rebuild_required": {
          "type": "boolean"
        },
        "policy_patch_required": {
          "type": "boolean"
        },
        "affected_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "error_classification": {
      "type": "object",
      "description": "issue_classification.yml 기준 오류 분류",
      "properties": {
        "category": {
          "type": "string",
          "description": "에러 코드 카테고리 (API, XML, CCH, MOD, NAV, FRM, SQL, STR, FW)"
        },
        "check_id": {
          "type": "string",
          "description": "verify 정책의 check ID (e.g., HC-017, XC-001)"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "warning"]
        }
      }
    },
    "actions_taken": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "patch, rebuild_request, reanalyze_request, policy_patch" },
          "target": { "type": "string" },
          "result": { "type": "string", "enum": ["success", "skipped", "failed"] },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "system_fix": {
      "type": "object",
      "description": "system-fix skill 호출 결과",
      "properties": {
        "invoked": { "type": "boolean" },
        "severity": { "type": ["string", "null"], "enum": ["high", "low", null] },
        "proposals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "target_file": { "type": "string" },
              "change_type": { "type": "string" },
              "applied": { "type": "boolean" },
              "backup_path": { "type": "string" }
            }
          }
        }
      }
    },
    "verify": {
      "type": "object",
      "description": "fix 적용 후 검증 결과 요약",
      "properties": {
        "critical_pass": { "type": "boolean" },
        "manual_required": { "type": "boolean" },
        "auto_fixed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "related_task_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verify_result_path": {
      "type": "string"
    },
    "cache": {
      "type": "object",
      "properties": {
        "used": {"type": "boolean"},
        "hit_categories": {"type": "array", "items": {"type": "string"}},
        "miss_categories": {"type": "array", "items": {"type": "string"}},
        "insufficient": {"type": "boolean"},
        "mismatch_detected": {"type": "boolean"},
        "db_fallback_used": {"type": "boolean"},
        "db_fallback_reason": {"type": "array", "items": {"type": "string"}},
        "db_fallback_status": {"type": ["string", "null"], "enum": ["success", "partial", "failed", null]}
      }
    }
  }
}