{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "verify_result.schema.json",
  "title": "Verify Result",
  "description": "Schema for verify_result.yml",
  "type": "object",
  "required": ["version", "stage", "status", "checks", "generated_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "stage": {
      "type": "string",
      "enum": ["build", "fix"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "result", "message"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique check identifier"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the check"
          },
          "result": {
            "type": "string",
            "enum": ["pass", "warn", "fail"]
          },
          "message": {
            "type": "string",
            "description": "Detail message about the check result"
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "cache_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {"type": "string"},
          "target": {"type": "string"},
          "result": {"type": "string", "enum": ["found", "not_found", "cache_empty"]},
          "message": {"type": "string"}
        }
      }
    },
    "cache_warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "cache_errors": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deploy_checks": {
      "type": "array",
      "description": "deploy 준비 단계 검증 결과",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "result": {"type": "string", "enum": ["pass", "warn", "fail", "skipped"]},
          "message": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "deploy_warnings": {
      "type": "array",
      "description": "deploy 관련 경고",
      "items": {"type": "string"}
    }
  }
}
