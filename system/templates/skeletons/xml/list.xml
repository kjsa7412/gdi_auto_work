<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="{{mapper_namespace}}">

    <!-- 목록 조회 -->
    <select id="{{select_sql_id}}" resultType="java.util.Map">
        /*{{mapper_namespace}}.{{select_sql_id}}*/
        SELECT
            {{grid_columns_sql}}
        FROM {{main_table}} a
        {{join_clauses}}
        WHERE 1=1
        {{search_conditions_sql}}
        ORDER BY {{order_columns}}
    </select>

    /* OPTIONAL: paging block start */
    <!-- 목록 카운트 (페이징용) -->
    <select id="{{select_sql_id}}Count" resultType="int">
        /*{{mapper_namespace}}.{{select_sql_id}}Count*/
        SELECT COUNT(*) AS cnt
        FROM {{main_table}} a
        {{join_clauses}}
        WHERE 1=1
        {{search_conditions_sql}}
    </select>
    /* OPTIONAL: paging block end */

    /* OPTIONAL: upsert-onconflict block start */
    <!-- 저장 (ON CONFLICT UPSERT) -->
    <insert id="{{insert_sql_id}}">
        /*{{mapper_namespace}}.{{insert_sql_id}}*/
        INSERT INTO {{main_table}} (
            {{insert_columns}},
            firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip,
            fina_reg_pgm_id, fina_reg_dts, fina_reg_user_id, fina_reg_ip
        ) VALUES (
            {{insert_values}},
            #{reg_pgm_id}, now(), #{login_user_id}, #{login_user_ip},
            #{reg_pgm_id}, now(), #{login_user_id}, #{login_user_ip}
        )
        ON CONFLICT ({{pk_columns}})
        DO UPDATE SET
            {{update_set_columns}},
            fina_reg_pgm_id = #{reg_pgm_id},
            fina_reg_dts = now(),
            fina_reg_user_id = #{login_user_id},
            fina_reg_ip = #{login_user_ip}
    </insert>
    /* OPTIONAL: upsert-onconflict block end */

    /* OPTIONAL: upsert-with block start */
    <!-- 저장 (WITH UPSERT) -->
    <!--
    <insert id="{{insert_sql_id}}">
        /*{{mapper_namespace}}.{{insert_sql_id}}*/
        WITH sdata AS (
        UPDATE {{main_table}}
        SET {{update_set_columns}},
            fina_reg_pgm_id = #{reg_pgm_id},
            fina_reg_dts = current_timestamp,
            fina_reg_user_id = #{login_user_id},
            fina_reg_ip = #{login_user_ip}
        WHERE {{pk_conditions}}
        RETURNING *
        )
        INSERT INTO {{main_table}} (
            {{insert_columns}},
            firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip
        )
        SELECT
            {{insert_values}},
            #{reg_pgm_id}, current_timestamp, #{login_user_id}, #{login_user_ip}
        WHERE NOT EXISTS (SELECT * FROM sdata)
    </insert>
    -->
    /* OPTIONAL: upsert-with block end */

    /* OPTIONAL: delete block start */
    <!-- 삭제 -->
    <delete id="{{delete_sql_id}}">
        /*{{mapper_namespace}}.{{delete_sql_id}}*/
        DELETE FROM {{main_table}}
        WHERE {{delete_conditions}}
    </delete>
    /* OPTIONAL: delete block end */

    /* OPTIONAL: choose-when dynamic branch start */
    <!-- 동적 분기 조건 (CHOOSE/WHEN) -->
    <!--
    <select id="{{select_sql_id}}ByType" resultType="java.util.Map">
        /*{{mapper_namespace}}.{{select_sql_id}}ByType*/
        SELECT
            {{grid_columns_sql}}
        FROM {{main_table}} a
        WHERE 1=1
        <choose>
            <when test='search_type == "A"'>
                AND a.type_cd = 'A'
            </when>
            <when test='search_type == "B"'>
                AND a.type_cd = 'B'
            </when>
            <otherwise>
                AND a.type_cd IS NOT NULL
            </otherwise>
        </choose>
        ORDER BY {{order_columns}}
    </select>
    -->
    /* OPTIONAL: choose-when dynamic branch end */

    /* OPTIONAL: foreach-in start */
    <!-- FOREACH IN 절 (배열 파라미터) -->
    <!--
    <select id="{{select_sql_id}}ByIds" resultType="java.util.Map">
        /*{{mapper_namespace}}.{{select_sql_id}}ByIds*/
