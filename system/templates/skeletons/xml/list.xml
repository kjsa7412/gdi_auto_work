            a.*,
            fn_code_nm('{{code_group}}', a.{{code_column}}) AS {{code_column}}_nm
        FROM {{main_table}} a
        WHERE 1=1
        {{search_conditions_sql}}
        ORDER BY {{order_columns}}
    </select>
    -->
    /* OPTIONAL: fn-function call end */

    /* OPTIONAL: cdata escape start */
    <!-- CDATA 부등호 이스케이프 -->
    <!--
    <select id="{{select_sql_id}}Range" resultType="java.util.Map">
        /*{{mapper_namespace}}.{{select_sql_id}}Range*/
