            {{grid_columns_sql}}
        FROM {{main_table}} a
        WHERE 1=1
          AND a.{{pk_column}} IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY {{order_columns}}
    </select>
    -->
    /* OPTIONAL: foreach-in end */

    /* OPTIONAL: fn-function call start */
    <!-- fn_* 함수 호출 (코드명 변환) -->
    <!--
    <select id="{{select_sql_id}}WithCodeNm" resultType="java.util.Map">
