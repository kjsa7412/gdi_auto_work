<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="{{mapper_namespace}}">

    /* VARIANT: search-type popup - 목록 조회 */
    <!-- 팝업 조회 -->
    <select id="{{select_sql_id}}" resultType="java.util.Map">
        /*{{mapper_namespace}}.{{select_sql_id}}*/
        SELECT
            {{grid_columns_sql}}
        FROM {{main_table}} a
        {{join_clauses}}
        WHERE 1=1
        {{search_conditions_sql}}
        ORDER BY {{order_columns}}
    </select>

