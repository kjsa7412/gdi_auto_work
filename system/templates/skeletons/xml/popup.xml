<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="{{mapper_namespace}}">

    /* VARIANT: search-type popup - 목록 조회 */
    <!-- 팝업 조회 -->
    <select id="{{select_sql_id}}" resultType="java.util.Map">
        SELECT
            {{grid_columns_sql}}
        FROM {{main_table}} a
        WHERE a.comp_cd = #{login_comp_cd}
        {{search_conditions_sql}}
        ORDER BY {{order_columns}}
    </select>

    /* VARIANT: input-type popup - 저장 처리 */
    /* OPTIONAL: insert block */
    <!--
    <insert id="{{insert_sql_id}}">
        INSERT INTO {{main_table}} (
            comp_cd,
            {{insert_columns}},
            firs_reg_pgm_id, firs_reg_dts, firs_reg_user_id, firs_reg_ip,
            fina_reg_pgm_id, fina_reg_dts, fina_reg_user_id, fina_reg_ip
        ) VALUES (
            #{login_comp_cd},
            {{insert_values}},
            #{reg_pgm_id}, now(), #{login_emp_no}, #{login_user_ip},
            #{reg_pgm_id}, now(), #{login_emp_no}, #{login_user_ip}
        )
    </insert>
    -->

    /* VARIANT: procedure call */
    /* OPTIONAL: procedure block */
    <!--
    <insert id="{{procedure_sql_id}}">
        CALL {{procedure_name}}(
            #{login_comp_cd},
            {{procedure_params}}
        )
    </insert>
    -->

</mapper>
